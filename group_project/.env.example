# Group project OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# Self-contained data/index behavior
AUTO_STANDARDIZE=true
AUTO_INDEX_ON_START=true
RESET_INDEX_ON_START=false

# Weaviate Local Docker
AUTO_START_DOCKER=true
WEAVIATE_LOCAL_HOST=localhost
WEAVIATE_LOCAL_HTTP_PORT=8080
WEAVIATE_LOCAL_GRPC_PORT=50051
WEAVIATE_COLLECTION=DrugLawChunk
WEAVIATE_START_TIMEOUT_SECONDS=90

# Chainlit
CHAINLIT_HOST=127.0.0.1
CHAINLIT_PORT=8000
CHAINLIT_AUTH_SECRET=3f982ea27b3708e332fbc13fa89b5c2a10d9f041b3d647e761df898fb3d34b22

# Local reranker
# BAAI/bge-reranker-v2-m3 is strong but large. Keep this model for final demo
# after downloading it once, or set a smaller CrossEncoder model for quick tests.
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
